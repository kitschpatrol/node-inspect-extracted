{
  "name": "node-inspect-extracted",
  "version": "3.3.2",
  "description": "Node's util.inspect, extracted for use on the Web",
  "main": "./dist/inspect.js",
  "module": "./index.mjs",
  "browser": "./dist/inspect.js",
  "exports": {
    "import": {
      "types": "./types/util.d.mts",
      "default": "./index.mjs"
    },
    "require": {
      "types": "./types/util.d.ts",
      "default": "./dist/inspect.js"
    }
  },
  "types": "./types/util.d.ts",
  "files": [
    "dist/",
    "types/",
    "index.mjs"
  ],
  "scripts": {
    "check": "node tools/check",
    "lint": "eslint .",
    "build": "webpack",
    "prepack": "npm run build",
    "pretest": "npm run build",
    "test": "node tools/runtests",
    "pretest:all": "npm run build",
    "test:all": "nve --arch ${NVE_ARCH:-`node -e 'console.log(process.arch)'`} -p 14,16,18,20,22,24,25 node tools/runtests",
    "coverage": "c8 node tools/runtests",
    "preci": "npm run build && npm run lint",
    "ci": "c8 nve --arch ${NVE_ARCH:-`node -e 'console.log(process.arch)'`} --no-progress -c -p 14,16,18,20,22,24,26 node tools/runtests"
  },
  "keywords": [
    "inspect",
    "util",
    "polyfill",
    "format",
    "output",
    "web",
    "browserify"
  ],
  "homepage": "https://github.com/hildjj/node-inspect-extracted",
  "repository": {
    "type": "git",
    "url": "http://github.com/hildjj/node-inspect-extracted.git"
  },
  "author": "Joe Hildebrand <joe-github@cursive.net>",
  "contributors": [
    "Noah May <noahmouse2011@gmail.com>"
  ],
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/plugin-syntax-import-source": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "babel-loader": "^10.1.1",
    "baseline-browser-mapping": "^2.11.0",
    "eslint": "^10.7.0",
    "eslint-plugin-jsdoc": "^63.2.0",
    "globals": "^17.7.0",
    "nve": "^18.0.3",
    "semver": "^7.8.5",
    "superc8": "^12.7.0",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=14"
  }
}
