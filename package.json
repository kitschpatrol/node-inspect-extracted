{
  "name": "node-inspect-extracted",
  "version": "3.3.1",
  "description": "Node's util.inspect, extracted for use on the Web",
  "main": "./dist/inspect.js",
  "module": "./index.mjs",
  "browser": "./dist/inspect.js",
  "exports": {
    "types": "./types/util.d.ts",
    "import": "./index.mjs",
    "require": "./dist/inspect.js"
  },
  "types": "./types/util.d.ts",
  "files": [
    "dist/",
    "types/",
    "index.mjs"
  ],
  "scripts": {
    "check": "node tools/check",
    "lint": "eslint .",
    "build": "webpack",
    "pretest": "npm run build",
    "test": "node tools/runtests",
    "pretest:all": "npm run build",
    "test:all": "nve --arch ${NVE_ARCH:-`node -e 'console.log(process.arch)'`} -p 14,16,18,20,22,24,25 node tools/runtests",
    "coverage": "c8 node tools/runtests",
    "preci": "npm run build && npm run lint",
    "ci": "c8 nve --arch ${NVE_ARCH:-`node -e 'console.log(process.arch)'`} --no-progress -c -p 14,16,18,20,22,24,25 node tools/runtests"
  },
  "keywords": [
    "inspect",
    "util",
    "polyfill",
    "format",
    "output",
    "web",
    "browserify"
  ],
  "homepage": "https://github.com/hildjj/node-inspect-extracted",
  "repository": {
    "type": "git",
    "url": "http://github.com/hildjj/node-inspect-extracted.git"
  },
  "author": "Joe Hildebrand <joe-github@cursive.net>",
  "contributors": [
    "Noah May <noahmouse2011@gmail.com>"
  ],
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "7.28.6",
    "@babel/plugin-syntax-import-source": "7.28.6",
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "10.0.1",
    "@eslint/markdown": "7.5.1",
    "@stylistic/eslint-plugin-js": "4.4.1",
    "babel-loader": "^10.0.0",
    "baseline-browser-mapping": "^2.10.0",
    "c8": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-jsdoc": "62.7.1",
    "globals": "17.4.0",
    "nve": "18.0.3",
    "semver": "7.7.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=14"
  },
  "pnpm": {
    "overrides": {
      "terser-webpack-plugin@5.3.16>serialize-javascript": "7.0.3"
    }
  }
}
